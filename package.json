{
  "name": "gudessence-tradeshow-app",
  "version": "1.0.0",
  "description": "",
  "main": "dist-electron/main.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "SIGNUP_SYNC_CONFIG=config/signup-sync.dev.json vite",
    "dev:cloud": "vite",
    "electron:dev": "electron src/main.js",
    "build": "vite build && vite build --mode electron-main",
    "preview": "npm run build && electron dist-electron/main.js",
    "build:win": "npm run build && electron-builder --win",
    "validate:show": "bash scripts/validate-show.sh",
    "validate:floor": "node scripts/validate-show-config.mjs config/signup-sync.show.json",
    "setup:show": "node scripts/setup-show-pc.mjs",
    "deploy:railway": "bash scripts/railway-phase1.sh"
  },
  "build": {
    "appId": "com.gudessence.tradeshow",
    "productName": "GŪDESSENCE Tradeshow App",
    "win": {
      "target": [
        "nsis"
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "preload.js",
      "package.json",
      "config/signup-sync.show.json",
      "config/staff.roster.show.json",
      "config/staff.roster.example.json",
      "public/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "howler": "^2.2.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-sounds": "^1.0.30",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "wait-on": "^9.0.10",
    "@ngrok/ngrok": "^1.4.1"
  }
}
